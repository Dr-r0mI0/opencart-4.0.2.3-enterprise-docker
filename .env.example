# 💻 إعدادات الحاوية والشبكات
CONTAINER_NAME=opencart-enterprise-prod
HOST_PORT=80                        # البورت على جهازك للتصفح

# 💾 إعدادات قاعدة البيانات المشتركة (تتصل بـ mariadb-store الحالية)
DB_HOST=mariadb-store
DB_PORT=3306
DB_NAME=opencart_db
DB_USER=opencart_admin
DB_PASSWORD=your_secure_password_here

# OpenCart Initial Admin Credentials
OC_ADMIN_USER=admin
OC_ADMIN_PASS=adminpass123
OC_ADMIN_EMAIL=admin@example.com
OC_ADMIN_DIR=admin-secure
